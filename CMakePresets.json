{
  "version": 2,

  "configurePresets": [
    {
      "name": "base",
      "hidden": true,

      "generator": "Ninja Multi-Config",
      "binaryDir": "${sourceDir}/build/${presetName}",

      "warnings": {
        "dev": true,
        "deprecated": true,
        "uninitialized": false
      },

      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",

        "CYBEL_OBJECT_LIB": true,
        "CYBEL_USE_LIBS": true,
        "CYBEL_USE_CONFIG_PKGS": true,

        "CYBEL_USE_SANITIZE": false,
        "CYBEL_USE_METRICS": false,
        "CYBEL_RENDERER": "GL"
      }
    },

    {
      "name": "default",
      "inherits": "base",

      "cacheVariables": {
        "CYBEL_RENDERER": "GL"
      }
    },
    {
      "name": "web",
      "inherits": "base",

      "cacheVariables": {
        "VCPKG_CHAINLOAD_TOOLCHAIN_FILE": "$env{EMSDK}/upstream/emscripten/cmake/Modules/Platform/Emscripten.cmake",
        "VCPKG_TARGET_TRIPLET": "wasm32-emscripten"
      }
    }
  ],

  "buildPresets": [
    {
      "name": "default",
      "configurePreset": "default",
      "nativeToolOptions": []
    },
    {
      "name": "web",
      "configurePreset": "web",
      "nativeToolOptions": []
    }
  ]
}
