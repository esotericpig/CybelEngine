@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

set(CYBEL_FIND_PKG_ARGS @CYBEL_FIND_PKG_ARGS@)
set(CYBEL_RENDERER_GLES @CYBEL_RENDERER_GLES@)

if(NOT EMSCRIPTEN)
  find_dependency(GLEW)
  find_dependency(OpenGL)
  find_dependency(SDL2 ${CYBEL_FIND_PKG_ARGS})
  find_dependency(SDL2_image ${CYBEL_FIND_PKG_ARGS})
  find_dependency(SDL2_mixer ${CYBEL_FIND_PKG_ARGS})
endif()

if(CYBEL_RENDERER_GLES)
  find_dependency(glm ${CYBEL_FIND_PKG_ARGS})
endif()

include("${CMAKE_CURRENT_LIST_DIR}/CybelEngineTargets.cmake")

check_required_components(CybelEngine)
