###
# See:
# - https://cmake.org/cmake/help/latest/guide/importing-exporting/index.html#creating-a-package-configuration-file
###

@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

set(CYBEL_USE_CONFIG_PKGS @CYBEL_USE_CONFIG_PKGS@)
set(CYBEL_RENDERER_GLES @CYBEL_RENDERER_GLES@)

if(NOT EMSCRIPTEN)
  find_dependency(GLEW)
  find_dependency(OpenGL)

  if(CYBEL_USE_CONFIG_PKGS)
    find_dependency(SDL2 CONFIG)
    find_dependency(SDL2_image CONFIG)
    find_dependency(SDL2_mixer CONFIG)
  else()
    find_dependency(SDL2)
    find_dependency(SDL2_image)
    find_dependency(SDL2_mixer)
  endif()
endif()

if(CYBEL_RENDERER_GLES)
  if(CYBEL_USE_CONFIG_PKGS)
    find_dependency(glm CONFIG)
  else()
    find_dependency(glm)
  endif()
endif()

include("${CMAKE_CURRENT_LIST_DIR}/CybelEngineTargets.cmake")

check_required_components(CybelEngine)
