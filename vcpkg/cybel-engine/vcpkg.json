{
  "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg-tool/main/docs/vcpkg.schema.json",

  "name": "cybel-engine",
  "version": "1.0",
  "license": "MPL-2.0",

  "homepage": "https://github.com/esotericpig/CybelEngine",
  "documentation": "https://github.com/esotericpig/CybelEngine",
  "description": "Cybel Engine is a simple C++ game engine using SDL2, OpenGL, and Emscripten.",

  "dependencies": [
    { "name": "vcpkg-cmake"       , "host": true },
    { "name": "vcpkg-cmake-config", "host": true },

    { "name": "glew"      , "platform": "!emscripten" },
    { "name": "opengl"    , "platform": "!emscripten" },
    { "name": "sdl2"      , "platform": "!emscripten", "version>=": "2.32.0" },
    { "name": "sdl2-image", "platform": "!emscripten", "version>=": "2.8.2"  },
    { "name": "sdl2-mixer", "platform": "!emscripten", "version>=": "2.8.0"  },

    { "name": "glm", "platform": "emscripten", "version>=": "1.0.0" }
  ],

  "features": {
    "gles": {
      "description": "OpenGL ES support for Desktop (already included for Web/Emscripten).",
      "dependencies": [
        { "name": "glm", "version>=": "1.0.0" }
      ]
    },
    "metrics": {
      "description": "Enable metrics, such as profiling and draw count."
    }
  }
}
